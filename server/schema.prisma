generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String     @id @default(cuid())
  email                 String     @unique
  firstName             String
  lastName              String
  organization          String?
  password              String     // bcrypt hashed
  passwordResetToken    String?
  passwordResetExpires  DateTime?
  refreshToken          String?    // JWT refresh token
  refreshTokenExpires   DateTime?

  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model Incident {
  id                    String   @id @default(cuid())
  incidentNumber        String   @unique // MDR-2024-0874 format
  severity              String   // Critical | High | Medium | Low
  status                String   // Open | InProgress | Resolved | Closed | InReview
  description           String
  incidentDate          DateTime
  facility              String
  reportedBy            String
  deviceName            String
  manufacturer          String

  attachments           String?  // JSON array of file URLs or references
  reportedAt            DateTime @default(now())

  investigation         Investigation?
  deviceInfo            DeviceInformation?
  rootCauseHypotheses   RootCauseHypothesis[]
  regulatoryFindings    RegulatoryFinding[]
  clinicalEvidence      ClinicalEvidence[]
  technicalFindings     TechnicalFinding[]
  agentActivities       AgentActivity[]
  auditLogs             AuditLog[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Investigation {
  id            String   @id @default(cuid())
  incidentId    String   @unique
  incident      Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  phase         String   // Intake | Analysis | Review | Closed
  assignedTo    String?

  findings      String?  // JSON array of findings
  notes         String?

  agentTasks    AgentTask[]
  reviewComments ReviewComment[]
  auditLogs     AuditLog[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AgentTask {
  id              String      @id @default(cuid())
  investigationId String
  investigation   Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  type            String      // Classification | RootCause | ReportGeneration
  status          String      // Pending | Running | Done | Failed
  result          String?     // JSON result from agent

  startedAt       DateTime?
  completedAt     DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model ReviewComment {
  id              String      @id @default(cuid())
  investigationId String
  investigation   Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  reviewer        String      // Reviewer name or ID
  comment         String      // Review comment text
  reviewStatus    String?     // approved | more-analysis | pending

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model DeviceInformation {
  id              String   @id @default(cuid())
  incidentId      String   @unique
  incident        Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  deviceName      String
  manufacturer    String
  model           String
  udi             String   @unique
  serialNumber    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RootCauseHypothesis {
  id              String   @id @default(cuid())
  incidentId      String
  incident        Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  title           String
  description     String?
  confidenceScore Int      // 0-100 percentage
  status          String   // Confirmed | Supporting | Excluded
  progressValue   Int?     // for progress bar

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RegulatoryFinding {
  id              String   @id @default(cuid())
  incidentId      String
  incident        Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  title           String
  regulationCode  String?
  description     String?
  severity        String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ClinicalEvidence {
  id              String   @id @default(cuid())
  incidentId      String
  incident        Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  title           String
  description     String
  meddrId         String?
  evidenceType    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TechnicalFinding {
  id              String   @id @default(cuid())
  incidentId      String
  incident        Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  cveId           String?
  title           String
  description     String
  affectedVersion String?
  patchAvailable  String?
  patchDate       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AgentActivity {
  id              String   @id @default(cuid())
  incidentId      String
  incident        Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  agentType       String   // Regulatory | Technical | Risk | Supervisor | Report
  agentName       String
  timestamp       DateTime
  status          String   // Result | Alert | Info | Complete
  message         String
  resultData      String?  // JSON result data

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id              String      @id @default(cuid())

  incidentId      String?
  incident        Incident?   @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  investigationId String?
  investigation   Investigation? @relation(fields: [investigationId], references: [id], onDelete: SetNull)

  action          String      // "created" | "updated" | "closed" | etc
  details         String?     // JSON details

  createdAt       DateTime    @default(now())
}
